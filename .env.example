# Groq API Key (Fastest inference engine for Llama models)
GROQ_API_KEY=your_groq_api_key_here

# Band SDK Credentials (from app.band.ai)
BAND_API_KEY=your_band_api_key_here

# Agent UUIDs (from agent dashboard url or info)
BAND_COORDINATOR_ID=your_coordinator_uuid_here
BAND_ANALYST_ID=your_analyst_uuid_here
BAND_AUDITOR_ID=your_auditor_uuid_here

# Agent Secret Tokens (from agent card '...' menu -> show secret token)
BAND_COORDINATOR_TOKEN=your_coordinator_token_here
BAND_ANALYST_TOKEN=your_analyst_token_here
BAND_AUDITOR_TOKEN=your_auditor_token_here

